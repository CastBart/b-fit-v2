{
  "permissions": {
    "allow": [
      "Bash(cmd /c dir /b)",
      "Bash(powershell -Command \"Get-ChildItem -Path .claude -Recurse -Name\")",
      "Bash(npx create-next-app@latest . --typescript --tailwind --eslint --app --src-dir --import-alias \"@/*\" --use-npm)",
      "Bash(npm install:*)",
      "Bash(npx tailwindcss:*)",
      "Bash(npx tsc:*)",
      "Bash(npm run build:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(timeout 10 npm run dev)",
      "Bash(git push:*)",
      "Bash(if [ -d \"app\" ])",
      "Bash(then echo \"app directory exists\")",
      "Bash(fi)",
      "Bash(if [ -d \"src\" ])",
      "Bash(then echo \"src directory exists\")",
      "Bash(npx shadcn@latest add button input card dialog dropdown-menu label form toast sheet avatar separator skeleton)",
      "Bash(npx shadcn@latest add button)",
      "Bash(npx shadcn@latest add sheet avatar separator skeleton sonner)",
      "Bash(npm run type-check:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run format:check:*)",
      "Bash(npx husky init)",
      "Bash(git rm:*)",
      "Bash(netstat:*)",
      "Bash(findstr:*)",
      "Bash(tree:*)",
      "Bash(npm run format:*)",
      "Bash(npx shadcn@latest add:*)",
      "Bash(npx tsx:*)",
      "Bash(npx prisma init)",
      "Bash(npx prisma migrate:*)",
      "Bash(npx prisma generate:*)",
      "Bash(rd /s /q \"node_modules\\\\@prisma\\\\client\")",
      "Bash(npx prisma:*)"
    ]
  },
  "enabledPlugins": {
    "everything-claude-code@everything-claude-code": true
  }
}
