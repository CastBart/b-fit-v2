// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - Core user entity for all user types
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  role          UserRole  @default(PERSONAL)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // Exercise relations
  exercises     Exercise[]

  // Workout relations
  workouts      Workout[]

  // Plan relations
  plans         Plan[]

  // Client relationship relations
  ptRelationships     ClientRelationship[] @relation("PTRelationships")
  clientRelationships ClientRelationship[] @relation("ClientRelationships")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

// NextAuth models for authentication
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// ENUMS
// ============================================================================

// Plan week tracking
enum PlanWeekStatus {
  IN_PROGRESS
  COMPLETED
}

enum DayCompletionStatus {
  COMPLETED
  SKIPPED
}

// User roles enum
enum UserRole {
  PERSONAL  // Personal user (trains themselves)
  PT        // Personal Trainer (trains themselves + manages clients)
  CLIENT    // Client (assigned to a PT)
  ORG       // Organisation (manages PTs)
}

// Client relationship status
enum RelationshipStatus {
  PENDING   // Invite sent, not yet accepted
  ACTIVE    // Client has accepted, relationship is active
  ENDED     // Relationship has been terminated by either party
}

// Exercise enums
enum ExerciseType {
  SMALL      // Isolation exercises
  MEDIUM     // Compound exercises
  LARGE      // Major compounds
  STABILITY  // Core and stabilization
  CARDIO     // Cardio exercises
}

enum MetricType {
  WEIGHT_REPS           // weight (kg/lbs) + reps
  COUNTER_WEIGHT_REPS   // assisted exercises (pull-up machine)
  REPS                  // bodyweight exercises (push-ups)
  REPS_DURATION         // timed holds with rep count
  DURATION              // planks, static holds
  DISTANCE_DURATION     // running, rowing
  WEIGHT_DISTANCE       // sled pushes, farmer carries
  WEIGHT_DURATION       // weighted holds
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  QUADS
  HAMSTRINGS
  GLUTES
  CALVES
  CORE
  FULL_BODY
}

enum EquipmentType {
  BARBELL
  DUMBBELL
  KETTLEBELL
  MACHINE
  CABLE
  BODYWEIGHT
  RESISTANCE_BAND
  TRX
  CARDIO_EQUIPMENT
}

enum MovementPattern {
  PUSH
  PULL
  SQUAT
  HINGE
  CARRY
  CORE
  LUNGE
  OLYMPIC
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ============================================================================
// EXERCISES
// ============================================================================

model Exercise {
  id          String   @id @default(cuid())
  name        String
  description String?

  // Categorization
  primaryMuscleGroup    MuscleGroup           // Single required value
  secondaryMuscleGroups MuscleGroup[]         // Optional array
  equipmentType         EquipmentType
  movementPattern       MovementPattern
  difficultyLevel       DifficultyLevel
  exerciseType          ExerciseType
  metricType            MetricType

  // Instructions
  instructions Json?  // Array of instruction strings

  // Ownership
  isDefault   Boolean @default(false)  // System seed exercises
  isPublic    Boolean @default(false)  // User-created, shared to community
  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workoutExercises    WorkoutExercise[]
  sessionExercises    SessionExercise[]
  planDayExercises    PlanDayExercise[]

  @@index([createdById])
  @@index([isDefault])
  @@index([equipmentType])
  @@index([exerciseType])
  @@index([primaryMuscleGroup])
}

// ============================================================================
// WORKOUTS
// ============================================================================

model Workout {
  id          String   @id @default(cuid())
  name        String
  description String?

  // Ownership
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  // Template vs Copy (for PT-to-Client assignment pattern)
  isTemplate   Boolean @default(true)
  copiedFromId String?  // Reference to original workout for client assignments
  copiedFrom   Workout? @relation("WorkoutCopies", fields: [copiedFromId], references: [id], onDelete: SetNull)
  copies       Workout[] @relation("WorkoutCopies")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  exercises WorkoutExercise[]

  @@index([createdById])
  @@index([copiedFromId])
  @@index([createdAt])
}

model WorkoutExercise {
  id String @id @default(cuid())

  // Relations
  workoutId  String
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  // Ordering & Grouping
  order   Int     // 0-indexed position in workout
  groupId String? // For supersets - exercises with same groupId form a superset

  // Target parameters
  sets        Int
  reps        Int?
  weight      Float?
  restSeconds Int     @default(60)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workoutId])
  @@index([exerciseId])
  @@index([groupId])
  @@unique([workoutId, order])  // Ensure unique ordering within workout
}

// ============================================================================
// TRAINING SESSIONS
// ============================================================================

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model TrainingSession {
  id     String        @id @default(cuid())
  status SessionStatus @default(IN_PROGRESS)

  // Optional workout reference (null for free sessions)
  workoutId String?
  // Note: No direct relation to Workout since workoutId might reference a deleted workout
  // We keep workoutId for historical reference only

  // Ownership
  userId String
  // Note: No direct relation to User to avoid complex cascade rules
  // Session cleanup should be handled by application logic

  // Session metadata
  name        String? // User-defined session name (especially for free sessions)
  notes       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Plan tracking (null for non-plan sessions)
  planId    String?
  planDayId String?

  // Relations
  exercises     SessionExercise[]
  sets          SessionSet[]
  dayCompletion PlanDayCompletion?

  @@index([userId])
  @@index([workoutId])
  @@index([status])
  @@index([startedAt])
  @@index([planId])
  @@index([planDayId])
}

model SessionExercise {
  id String @id @default(cuid())

  // Relations
  sessionId  String
  session    TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  // Instance tracking (for multiple instances of same exercise in session)
  instanceId String // UUID to uniquely identify this exercise instance

  // Ordering & Grouping (copied from WorkoutExercise or set manually for free sessions)
  order   Int     // 0-indexed position in session
  groupId String? // For supersets

  // Target parameters (copied from WorkoutExercise or set manually)
  targetSets        Int
  targetReps        Int?
  targetWeight      Float?
  targetRestSeconds Int     @default(60)
  notes             String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sets SessionSet[]

  @@index([sessionId])
  @@index([exerciseId])
  @@index([instanceId])
  @@index([groupId])
  @@unique([sessionId, order]) // Ensure unique ordering within session
}

model SessionSet {
  id String @id @default(cuid())

  // Relations
  sessionId         String
  session           TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionExerciseId String
  sessionExercise   SessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)

  // Set number (1-indexed)
  setNumber Int

  // Metrics (based on exercise's MetricType)
  // Only relevant fields will be populated based on metricType
  weight        Float?
  reps          Int?
  duration      Int? // seconds
  distance      Int? // meters
  counterWeight Float? // for assisted exercises (e.g., pull-up machine)

  // Set metadata
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  notes       String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([sessionExerciseId])
  @@index([isCompleted])
  @@unique([sessionExerciseId, setNumber]) // Ensure unique set numbers per exercise
}

// ============================================================================
// PLANS
// ============================================================================

model Plan {
  id          String   @id @default(cuid())
  name        String
  description String?

  // Plan configuration
  daysPerWeek   Int // 1-7
  durationWeeks Int @default(0) // 0 = unlimited, 1-52

  // Activation
  isActive    Boolean   @default(false)
  activatedAt DateTime?

  // Ownership
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  // Template vs Copy (mirrors Workout pattern)
  isTemplate   Boolean @default(true)
  copiedFromId String?
  copiedFrom   Plan?   @relation("PlanCopies", fields: [copiedFromId], references: [id], onDelete: SetNull)
  copies       Plan[]  @relation("PlanCopies")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  days  PlanDay[]
  weeks PlanWeek[]

  @@index([createdById])
  @@index([isActive])
  @@index([copiedFromId])
  @@index([createdAt])
}

model PlanDay {
  id String @id @default(cuid())

  // Relations
  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Day configuration
  dayNumber Int     // 1 through daysPerWeek
  label     String? // Optional label (e.g., "Push Day", "Leg Day")

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  exercises   PlanDayExercise[]
  completions PlanDayCompletion[]

  @@unique([planId, dayNumber])
  @@index([planId])
}

model PlanDayExercise {
  id String @id @default(cuid())

  // Relations
  planDayId  String
  planDay    PlanDay  @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  // Ordering & Grouping
  order   Int     // 0-indexed position in day
  groupId String? // For supersets

  // Target parameters
  sets        Int
  reps        Int?
  weight      Float?
  restSeconds Int     @default(60)
  notes       String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planDayId])
  @@index([exerciseId])
  @@index([groupId])
  @@unique([planDayId, order])
}

// ============================================================================
// PLAN WEEK TRACKING
// ============================================================================

model PlanWeek {
  id          String         @id @default(cuid())
  planId      String
  plan        Plan           @relation(fields: [planId], references: [id], onDelete: Cascade)
  weekNumber  Int
  status      PlanWeekStatus @default(IN_PROGRESS)
  startedAt   DateTime       @default(now())
  completedAt DateTime?

  dayCompletions PlanDayCompletion[]

  @@unique([planId, weekNumber])
  @@index([planId])
  @@index([status])
}

model PlanDayCompletion {
  id          String              @id @default(cuid())
  planWeekId  String
  planWeek    PlanWeek            @relation(fields: [planWeekId], references: [id], onDelete: Cascade)
  planDayId   String
  planDay     PlanDay             @relation(fields: [planDayId], references: [id], onDelete: Cascade)
  status      DayCompletionStatus @default(COMPLETED)
  sessionId   String?             @unique
  session     TrainingSession?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  completedAt DateTime            @default(now())

  @@unique([planWeekId, planDayId])
  @@index([planWeekId])
  @@index([planDayId])
  @@index([sessionId])
}

// ============================================================================
// CLIENT RELATIONSHIPS
// ============================================================================

model ClientRelationship {
  id          String             @id @default(cuid())

  // PT who owns the relationship
  ptId        String
  pt          User               @relation("PTRelationships", fields: [ptId], references: [id], onDelete: Cascade)

  // Client (null while PENDING - set when invite is accepted)
  clientId    String?
  client      User?              @relation("ClientRelationships", fields: [clientId], references: [id], onDelete: Cascade)

  // Relationship state
  status      RelationshipStatus @default(PENDING)
  inviteCode  String             @unique
  clientEmail String?            // Optional: PT can record intended client email

  // Timestamps
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([ptId, clientId])
  @@index([ptId])
  @@index([clientId])
  @@index([status])
  @@index([inviteCode])
}
